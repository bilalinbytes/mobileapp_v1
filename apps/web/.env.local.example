# -----------------------------------------------------------------------------
# Saans Sync - Environment Variables Reference
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# -----------------------------------------------------------------------------

# -- Supabase ------------------------------------------------------------------
# Get from: Supabase dashboard -> Project Settings -> API

# Public - safe to expose to the browser. RLS protects all data.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only - NEVER prefix with NEXT_PUBLIC_. Used only in API routes.
# Bypasses RLS. Only use for audit_logs inserts and scoring engine writes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -- WAQI (Air Quality Index) --------------------------------------------------
# Get from: https://aqicn.org/data-platform/token/
# Free. 1000 requests/day. Server-only - never expose to client.
WAQI_API_TOKEN=your-waqi-token

# -- Firebase (Push Notifications) ---------------------------------------------
# optional — not yet wired in code
# Get from: Firebase Console -> Project Settings -> Service Accounts -> Generate new private key
# Server-only keys:
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Public Firebase config (safe to expose - used in Expo app):
EXPO_PUBLIC_FIREBASE_API_KEY=your-api-key
EXPO_PUBLIC_FIREBASE_APP_ID=your-app-id
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id

# -- Upstash Redis --------------------------------------------------------------
# optional — not yet wired in code
# Get from: upstash.com -> console -> your Redis DB -> REST API tab
# Server-only. Used for offline log deduplication and AQI caching.
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-rest-token

# -- Cloudflare R2 (Export Storage) --------------------------------------------
# Get from: Cloudflare dashboard -> R2 -> Manage R2 API Tokens
# Server-only.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=respiratory-exports

# -- Sentry (Error Tracking) ----------------------------------------------------
# optional — not yet wired in code
# Get from: sentry.io -> your project -> Settings -> Client Keys (DSN)
# DSN is safe to expose.
SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# -- Twilio (SMS/OTP Delivery) -------------------------------------------------
# Get from: https://www.twilio.com/console
# Used by the custom patient-auth system to deliver OTPs via SMS.
# If these are not configured, the system falls back to console.log logging.
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number-or-messaging-service-sid

